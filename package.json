{
  "name": "scafix",
  "version": "1.0.1",
  "description": "A universal scaffolding CLI that initializes modern application stacks through a single, consistent interface",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "scafix": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsup",
    "build:watch": "tsup --watch",
    "format": "prettier --write \"**/*.{js,json,ts,md}\"",
    "push": "git add . && git commit -m 'chore: push changes' && git push",
    "smoke": "tsup && node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:smoke": "node scripts/run-network-smoke.mjs"
  },
  "keywords": [
    "cli",
    "Scafix",
    "scaffolding",
    "project-generator",
    "universal-scaffolder"
  ],
  "author": "Toufiq Hasan Kiron <hello@kiron.dev>",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kiron0/scafix.git"
  },
  "homepage": "https://scafix.js.org",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "validate-npm-package-name": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.8.1",
    "terser": "^5.46.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
