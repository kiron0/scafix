{
          "name": "scafix",
          "version": "0.0.1",
          "description": "A universal scaffolding CLI that initializes modern application stacks through a single, consistent interface",
          "type": "module",
          "main": "dist/index.js",
          "bin": {
                    "scafix": "./dist/index.js"
          },
          "scripts": {
                    "start": "node dist/index.js",
                    "build": "rm -rf dist && tsup",
                    "build:watch": "tsup --watch",
                    "format": "prettier --write \"**/*.{js,json,ts,md}\""
          },
          "keywords": [
                    "cli",
                    "Scafix",
                    "scaffolding",
                    "project-generator",
                    "universal-scaffolder"
          ],
          "author": "Toufiq Hasan Kiron <hello@kiron.dev>",
          "license": "MIT",
          "files": [
                    "dist",
                    "README.md",
                    "LICENSE"
          ],
          "repository": {
                    "type": "git",
                    "url": "https://github.com/kiron0/scafix.git"
          },
          "homepage": "https://scafix.js.org",
          "dependencies": {
                    "chalk": "^5.6.2",
                    "commander": "^14.0.2",
                    "fast-glob": "^3.3.3",
                    "ignore": "^7.0.5",
                    "prompts": "^2.4.2"
          },
          "devDependencies": {
                    "@types/node": "^25.0.3",
                    "@types/prompts": "^2.4.9",
                    "prettier": "^3.7.4",
                    "terser": "^5.44.1",
                    "tsup": "^8.5.1",
                    "typescript": "^5.9.3"
          }
}
